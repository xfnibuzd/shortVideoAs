# 服务端口
PORT=3000

# 选择图片生成服务商：gemini（默认）| doubao
AI_PROVIDER=gemini

# ===== Google Gemini =====
# Google Gemini API Key（不要提交真实密钥），任一变量名均可被识别
GOOGLE_API_KEY=
GEMINI_API_KEY=
# Gemini 图片生成模型
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# ===== 豆包 / 火山方舟 Ark =====
# 火山方舟 API Key（控制台获取）
ARK_API_KEY=
# 图片生成模型（或推理接入点 ep-xxxx）
DOUBAO_IMAGE_MODEL=doubao-seedream-3-0-t2i-250415
# 可选：Base URL 与图片尺寸
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_IMAGE_SIZE=2048x2048  # Seedream 要求像素数 >= 3686400(约1920x1920)

# 出站代理（仅 Gemini 需要时填写；AI_PROVIDER=doubao 时会自动忽略）
# HTTPS_PROXY=http://127.0.0.1:7897
